{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HanPage",
  "version": "0.7.13",
  "identifier": "com.paldyn.hanpage",
  "build": {
    "frontendDist": "../../rhwp-studio/dist",
    "devUrl": "http://127.0.0.1:7700",
    "beforeBuildCommand": "npm run build:frontend",
    "beforeDevCommand": "npm run dev:frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "HanPage",
        "width": 1200,
        "height": 840,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
